// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "vim_mode": false,
  "ensure_final_newline_on_save": false,
  "languages": {
    "Markdown-Inline": {
      "soft_wrap": "prefer_line"
    },
    "Zig": {
      // Formatting with ZLS matches `zig fmt`.
      "formatter": "language_server",
      "format_on_save": "on",
      // Make sure that zls is the primary language server
      "language_servers": ["zls"],
      "code_actions_on_format": {
        // Run code actions that currently supports adding and removing discards.
        // "source.fixAll": true,
        // Run code actions that sorts @import declarations.
        // "source.organizeImports": true,
      }
    }
  },
  "lsp": {
    "zls": {
      // There are two ways to set config options:
      //   - edit your `zls.json` that applies to any editor that uses ZLS
      //   - set in-editor config options with the `settings` field below.
      //
      // Further information on how to configure ZLS:
      // https://zigtools.org/zls/configure/
      "settings": {
        "zls": {
          // "enable_build_on_save": true,
          // "enable_autofix": true,
          // "warn_style": true,
          // "highlight_global_var_declarations": true
          // Whether to enable build-on-save diagnostics
          //
          // Further information about build-on save:
          // https://zigtools.org/zls/guides/build-on-save/
          // "enable_build_on_save": true,
          // omit the following line if `zig` is in your PATH
          // "zig_exe_path": "/opt/homebrew/bin/zls"
        }
      }
    }
  },
  "edit_predictions": {
    "provider": "copilot",
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
      "enterprise_uri": null
    },
    "enabled_in_text_threads": false
  },
  "agent": {
    "tool_permissions": {
      "tools": {
        "restore_file_from_disk": {
          "default": "allow"
        },
        "fetch": {
          "default": "allow",
          "always_allow": [
            {
              "pattern": "^https?://nuqs\\.dev"
            }
          ]
        },
        "create_directory": {
          "default": "allow",
          "always_allow": [
            {
              "pattern": "^apps/frontend/apps/nyheter/src/pages/"
            }
          ]
        },
        "terminal": {
          "default": "allow"
        }
      }
    },
    "default_profile": "write",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6"
    },
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.5"
    }
  },
  // "buffer_font_family": "Iosevka",
  "buffer_font_size": 15,
  "ui_font_size": 16,
  "buffer_font_features": {
    "calt": false
  },
  "theme": {
    "mode": "system",
    "light": "Catppuccin Frappé - No Italics",
    "dark": "One Dark"
  },
  "diagnostics": {
    "inline": {
      "min_column": 0,
      "padding": 0,
      "enabled": true,
      "max_severity": null // same values as the `diagnostics_max_severity` from the editor settings
    }
  }
}
